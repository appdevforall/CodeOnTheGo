<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="GIS Plugin"
        android:theme="@style/PluginTheme">

        <!-- Plugin metadata -->
        <meta-data
            android:name="plugin.id"
            android:value="com.codeonthego.gisplugin" />

        <meta-data
            android:name="plugin.name"
            android:value="GIS (OpenStreetMap)" />

        <meta-data
            android:name="plugin.version"
            android:value="${pluginVersion}" />

        <meta-data
            android:name="plugin.description"
            android:value="Project templates and tools for offline OpenStreetMap apps. Adds 'OSM Map - read-only POIs' and 'OSM Map - annotate' templates plus a 'Map Regions' sidebar entry for cache management." />

        <meta-data
            android:name="plugin.author"
            android:value="App Dev For All" />

        <meta-data
            android:name="plugin.min_ide_version"
            android:value="2.1.0" />

        <meta-data
            android:name="plugin.permissions"
            android:value="filesystem.read,filesystem.write,network.access" />

        <meta-data
            android:name="plugin.main_class"
            android:value="com.codeonthego.gisplugin.GisPlugin" />

        <!-- Sidebar entry: 1 item ("Map Regions"). -->
        <meta-data
            android:name="plugin.sidebar_items"
            android:value="1" />

        <!--
            No <activity> declarations: plugin APKs are loaded with
            DexClassLoader and never registered with the host's
            PackageManager, so plugin-Activity launches via Intent fail at
            runtime. UI lives in Fragments hosted under the IDE's editor
            tab system (see GisPlugin.getMainEditorTabs).
        -->

    </application>

</manifest>

[*.{kt,kts}]

# Enable IntelliJ formatter tags to allow enabling/disabling ktlint for a
# specific part of code.
ij_formatter_tags_enabled = true

# @Composable functions are PascalCase by convention, which conflicts with the
# standard:function-naming rule. Let the compose-rules ruleset (wired into
# spotless) validate Composable naming instead.
ktlint_function_naming_ignore_when_annotated_with = Composable
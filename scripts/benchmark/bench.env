# Benchmark run configuration.
#
# Sourced by .github/workflows/build-benchmark.yml on PUSH to the benchmarking
# branch (push events cannot carry workflow_dispatch inputs). To run a config:
# edit the values below, commit, and push — only build-benchmark.yml runs
# (debug.yml is suppressed for this branch), and each config change is a
# self-documenting commit. See docs/superpowers/plans/2026-07-09-ci-build-
# benchmark-and-runner-reclaim.md (Task 4) for the Phase A–D matrix.
#
# Only simple KEY=VALUE lines (no spaces in the value) are read.
#
# Defaults below reproduce the current production config (Phase A baseline).

VARIANT=v8-debug
ENABLE_DAEMON=true
GRADLE_DAEMON_HEAP=8192M
KOTLIN_DAEMON_HEAP=8192M
AAPT2_HEAP=8192M
WORKERS_MAX=30
PARALLEL=true
CLEAN_FIRST=true

<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/fs_ghost_pressed" />
            <corners android:radius="@dimen/fs_corner" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/fs_surface" />
            <corners android:radius="@dimen/fs_corner" />
            <stroke android:width="1dp" android:color="@color/fs_divider" />
        </shape>
    </item>
</selector>

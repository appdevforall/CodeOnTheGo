<?xml version="1.0" encoding="utf-8"?>
<!-- Survey capture screen. Question rows are built programmatically once the
     async assets/questions.json load completes (count is data-driven). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fs_bg"
    android:padding="@dimen/fs_pad">

    <TextView
        android:id="@+id/survey_site"
        style="@style/FS.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/survey_hint"
        style="@style/FS.Subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/fs_survey_hint" />

    <TextView
        android:id="@+id/survey_loading"
        style="@style/FS.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/fs_pad"
        android:text="@string/fs_loading"
        android:textColor="@color/fs_muted" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/fs_pad_small"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/survey_questions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/fs_pad_small"
        android:orientation="horizontal">

        <Button
            android:id="@+id/survey_cancel"
            style="@style/FS.Button.Ghost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/fs_cancel" />

        <Button
            android:id="@+id/survey_save"
            style="@style/FS.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/fs_pad_small"
            android:enabled="false"
            android:text="@string/fs_save" />

    </LinearLayout>

</LinearLayout>

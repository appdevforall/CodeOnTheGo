 }
+
+/**
+ * returns a number in the range [startAt, startAt + 2PI). Fills the same Double/Float overload
+ * gap that the real upstream fix above closed for normalizeDegrees (StreetComplete PR #6307,
+ * "Fix angle normalization with non-zero startAt parameter") -- normalizeRadians only had a
+ * Double overload before this edit.
+ */
+fun normalizeRadians(value: Float, startAt: Float = 0f): Float {
+    val pi2 = (PI * 2).toFloat()
+    var result = (value - startAt) % pi2
+    if (result < 0) result += pi2
+    return result + startAt
+}
